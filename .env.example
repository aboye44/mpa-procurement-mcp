# SAM.gov API Key (get from https://sam.gov/profile/details)
SAM_GOV_API_KEY=your-sam-gov-api-key

# BidNet Direct credentials
BIDNET_EMAIL=alec@mailpro.org
BIDNET_PASSWORD=your-bidnet-password

# MFMP credentials (MyFloridaMarketPlace)
# Also used for FL VBS vendor dashboard
MFMP_EMAIL=alec@mailpro.org
MFMP_PASSWORD=your-mfmp-password

# Bonfire/Euna credentials
BONFIRE_EMAIL=alec@mailpro.org
BONFIRE_PASSWORD=your-bonfire-password

# DemandStar (public — no login needed for search)
# No credentials required

# GPO Publish credentials (publish.gpo.gov / ims.gpo.gov)
# Small purchase API is public, but award results and quote submission need auth
GPO_EMAIL=alec@mailpro.org
GPO_PASSWORD=your-gpo-password

# BidSync / Periscope S2G credentials (app.bidsync.com)
# Public agency pages work without login. Full search requires account ($109/mo FL plan).
BIDSYNC_EMAIL=alec@mailpro.org
BIDSYNC_PASSWORD=your-bidsync-password

# USPS Coupa Supplier Portal (usps.coupahost.com)
# Register at: https://about.usps.com/suppliers/becoming/registration.htm
# Email eSourcing@usps.gov with initial supplier form to get access
USPS_COUPA_EMAIL=alec@mailpro.org
USPS_COUPA_PASSWORD=your-usps-coupa-password

# OpenGov, IonWave, FL Counties, FL VBS — No credentials needed (public portals)

# Google Sheets API (direct — uses service account for ~200ms calls vs 1.5-5.7s through Pipedream)
# 1. Create a Google Cloud project: https://console.cloud.google.com
# 2. Enable the Google Sheets API
# 3. Create a service account and download the JSON key
# 4. Share the spreadsheet with the service account email (Editor access)
# See SETUP.md for step-by-step instructions.
GOOGLE_SHEETS_CREDS_PATH=./credentials/google-service-account.json
PROCUREMENT_SHEET_ID=1ze-9C0g924sotn3emm5j7N_jtw-MvRiBWDrh1T1tJa8

# Feed export path (where to save the consolidated JSON feed)
FEED_PATH=./data/procurement_feed.json

# Database path (JSON tracker)
DB_PATH=./data/tracker.db
